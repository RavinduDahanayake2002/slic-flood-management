@using Microsoft.JSInterop
@using FloodApp.Services
@using FloodApp.State
@using FloodApp.Models
@inject IJSRuntime JS
@inject GeoJsonService GeoJsonService
@inject AppState AppState

<div id="risk-map" class="h-full w-full"></div>

@code {
    [Parameter]
    public List<Shelter> Shelters { get; set; } = new();

    [Parameter]
    public string RiskLevelString { get; set; } = "Low";

    private IJSObjectReference? _mapModule;
    private IJSObjectReference? _mapInstance;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AppState.SelectedLatLng != null)
        {
            var cacheBuster = Guid.NewGuid().ToString("N");
            _mapModule = await JS.InvokeAsync<IJSObjectReference>("import", $"./js/map.js?v={cacheBuster}");
            
            var center = new { lat = AppState.SelectedLatLng.Lat, lng = AppState.SelectedLatLng.Lng };
            _mapInstance = await _mapModule.InvokeAsync<IJSObjectReference>("initMap", "risk-map", center, 13, null);
            
            // Add Zones
            // var geoJson = await GeoJsonService.GetRiskZonesGeoJsonAsync();
            // var parsed = System.Text.Json.JsonDocument.Parse(geoJson).RootElement;
            // await _mapModule.InvokeVoidAsync("addGeoJson", _mapInstance, parsed, "defaultStyle");
            
            // Add Colored Blast Radius
            await _mapModule.InvokeVoidAsync("addRiskRadius", _mapInstance, AppState.SelectedLatLng.Lat, AppState.SelectedLatLng.Lng, RiskLevelString);
            
            // Add Shelters
            foreach (var s in Shelters)
            {
                var popupText = $"<div style='color:black;'><b>{s.Name}</b><br>{s.Type} - {s.DistanceKm:F1}km away</div>";
                await _mapModule.InvokeVoidAsync("addShelterMarker", _mapInstance, s.Lat, s.Lng, popupText);
            }
        }
    }
}
