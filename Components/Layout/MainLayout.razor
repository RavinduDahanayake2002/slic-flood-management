@inherits LayoutComponentBase
@inject NavigationManager Navigation
@implements IDisposable

<div class="app-layout">
    <!-- Global Slim Top Navbar -->
    <header class="global-navbar">
        <div class="nav-container">
            @if (Navigation.Uri.Contains("/premium"))
            {
                <button @onclick="@(() => Navigation.NavigateTo("/location"))" class="nav-back-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19l-7-7 7-7"/></svg>
                    Back
                </button>
            }
            else
            {
                <div class="nav-brand">
                    <span class="brand-accent">SLIC</span> Flood Management
                </div>
                <nav class="nav-links">
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">Home</NavLink>
                    <NavLink href="/location" class="nav-link">Flood Risk</NavLink>
                    <NavLink href="/history" class="nav-link">Flood History</NavLink>
                    <NavLink href="/premium" class="nav-link">Premium Calculation</NavLink>
                </nav>
            }
        </div>
    </header>

    <main class="content page-enter">
        @Body
    </main>
</div>

<style>
    .app-layout {
        min-height: 100vh;
        background-color: var(--bg-dark);
        color: var(--text-main);
        display: flex;
        flex-direction: column;
    }
    
    .global-navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        width: 100%;
        background: rgba(13, 27, 42, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-soft);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .nav-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0.75rem 1rem;
        gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .nav-container {
            padding: 0.75rem 2rem;
        }
    }

    .nav-brand {
        font-weight: 700;
        font-size: 1.25rem;
        color: white;
        letter-spacing: 1px;
        flex-shrink: 0;
    }

    .brand-accent {
        color: var(--color-teal-mid);
    }

    .nav-links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        overflow-x: auto;
        white-space: nowrap;
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE and Edge */
        padding-bottom: 2px;
    }
    
    .nav-links::-webkit-scrollbar {
        display: none; /* Chrome, Safari and Opera */
    }

    .nav-link {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.2s, text-shadow 0.2s;
    }

    .nav-link:hover, .nav-link.active {
        color: var(--color-teal-mid);
        text-shadow: 0 0 10px rgba(0, 178, 170, 0.5);
    }

    .nav-back-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        border: none;
        color: #94a3b8;
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        transition: color 0.2s;
        padding: 0;
    }

    .nav-back-btn:hover {
        color: var(--color-teal-top);
        text-shadow: 0 0 10px rgba(0, 188, 212, 0.5);
    }

    .content {
        flex: 1;
        width: 100%;
        overflow-x: hidden;
    }
</style>


@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
