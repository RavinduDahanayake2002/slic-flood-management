@using FloodApp.Services
@using FloodApp.State
@using FloodApp.Models
@using FloodApp.Components.UI
@inject LocationService LocationService
@inject AppState AppState
@inject NavigationManager Nav
@inject GeocodingService GeocodingService

<div class="location-form flex flex-col gap-4">
    <Panel Class="flex flex-col gap-6">
        <h2 class="text-xl">Select Location</h2>
        
        <!-- Province -->
        <AppSelect Label="Province" 
                   Placeholder="Select Province"
                   Items="@Provinces.Select(p => new AppSelect.SelectOption { Text = p.Name, Value = p.Id })"
                   SelectedValue="@AppState.SelectedProvinceId"
                   SelectedValueChanged="@OnProvinceChanged" 
                   Class="w-full" />

        <!-- District -->
        <AppSelect Label="District" 
                   Placeholder="Select District"
                   Items="@Districts.Select(d => new AppSelect.SelectOption { Text = d.Name, Value = d.Id })"
                   SelectedValue="@AppState.SelectedDistrictId"
                   SelectedValueChanged="@OnDistrictChanged" 
                   Class="w-full" />

        <!-- Division -->
        <AppSelect Label="Division" 
                   Placeholder="Select Division"
                   Items="@Divisions.Select(div => new AppSelect.SelectOption { Text = div.Name, Value = div.Id })"
                   SelectedValue="@AppState.SelectedDivisionId"
                   SelectedValueChanged="@OnDivisionChanged" 
                   Class="w-full" />

        <div class="text-center text-secondary text-sm font-medium mt-1 mb-1">OR</div>

        <!-- Full Address -->
        <div class="app-input-group">
            <label class="app-input-label">Full Address</label>
            <textarea class="app-textarea" 
                      placeholder="Example: No 21 Vauxhall Street, Colombo 00200, Sri Lanka"
                      @bind="addressText"
                      @bind:event="oninput"></textarea>
            @if (!string.IsNullOrEmpty(_geocodeError))
            {
                <div class="text-red-400 text-xs mt-1">@_geocodeError</div>
            }
        </div>

        <div class="flex flex-col gap-3 mt-4">
            <AppButton Color="AppButton.ButtonColor.Primary" 
                       Disabled="@(!CanProceed || _isGeocoding)"
                       OnClick="@CheckRisk">
                @if (_isGeocoding)
                {
                    <span>Locating...</span>
                }
                else
                {
                    <span>Check Risk</span>
                }
            </AppButton>
            
            <div class="text-center text-secondary text-sm">OR</div>
            
            <AppButton Variant="AppButton.ButtonVariant.Outline" 
                       Color="AppButton.ButtonColor.Neutral"
                       OnClick="@(() => Nav.NavigateTo("/choose-on-map"))">
                Choose on Map    
            </AppButton>
        </div>
    </Panel>
</div>

@code {
    private string? addressText
    {
        get => AppState.FullAddress;
        set => AppState.SetFullAddress(value);
    }
    
    private bool _isGeocoding = false;
    private string? _geocodeError = null;

    private List<Province> Provinces => LocationService.GetProvinces();
    private List<District> Districts => AppState.SelectedProvinceId.HasValue 
        ? LocationService.GetDistricts(AppState.SelectedProvinceId.Value) 
        : new();
    private List<Division> Divisions => AppState.SelectedDistrictId.HasValue 
        ? LocationService.GetDivisions(AppState.SelectedDistrictId.Value) 
        : new();
    private List<Town> Towns => AppState.SelectedDivisionId.HasValue 
        ? LocationService.GetTowns(AppState.SelectedDivisionId.Value) 
        : new();

    private bool CanProceed => AppState.SelectedDivisionId.HasValue || !string.IsNullOrWhiteSpace(addressText);

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private void OnProvinceChanged(object? value)
    {
        if (value is int id)
        {
            var p = Provinces.FirstOrDefault(x => x.Id == id);
            AppState.SetProvince(id, p?.Coords);
        }
        else
            AppState.SetProvince(null);
    }

    private void OnDistrictChanged(object? value)
    {
        if (value is int id)
        {
            var d = Districts.FirstOrDefault(x => x.Id == id);
            AppState.SetDistrict(id, d?.Coords);
        }
        else
            AppState.SetDistrict(null);
    }

    private void OnDivisionChanged(object? value)
    {
        if (value is int id)
        {
            var div = Divisions.FirstOrDefault(x => x.Id == id);
            AppState.SetDivision(id, div?.Coords, div?.Name);
        }
        else
            AppState.SetDivision(null);
    }

    private void OnTownChanged(object? value)
    {
        if (value is int id)
        {
            var town = LocationService.GetTown(id);
            AppState.SetTown(id, town?.Coords, town?.Name);
        }
        else
        {
            AppState.SetTown(null, null, null);
        }
    }

    private async Task CheckRisk()
    {
        _geocodeError = null;

        if (!string.IsNullOrWhiteSpace(addressText))
        {
            _isGeocoding = true;
            StateHasChanged();

            try
            {
                var geocoded = await GeocodingService.GeocodeAsync(addressText);

                if (geocoded == null)
                {
                    _geocodeError = "Address not found. Please try a more specific address (e.g. \"No 21 Vauxhall Street, Colombo\") or use the dropdowns.";
                }
                else if (!GeocodingService.IsInSriLanka(geocoded.Lat, geocoded.Lon))
                {
                    _geocodeError = "⚠️ The address found is outside Sri Lanka. Please enter a valid Sri Lankan address.";
                }
                else
                {
                    AppState.SetFullAddress(addressText);
                    AppState.SetCustomLocation(new LatLng(geocoded.Lat, geocoded.Lon), addressText);
                    Nav.NavigateTo("/risk");
                }
            }
            catch (Exception ex)
            {
                _geocodeError = "Error looking up address. Please try again or use the dropdowns.";
                Console.WriteLine($"Geocoding error: {ex.Message}");
            }
            finally
            {
                _isGeocoding = false;
                StateHasChanged();
            }
        }
        else if (AppState.SelectedDivisionId.HasValue)
        {
            Nav.NavigateTo("/risk");
        }
    }
}

<style>
    .app-input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        position: relative;
    }

    .app-input-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
    }

    .app-textarea {
        width: 100%;
        padding: 0.625rem 1rem;
        background-color: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        color: var(--text-primary);
        font-size: 0.875rem;
        resize: vertical;
        min-height: 80px;
        transition: all 0.2s;
        font-family: inherit;
    }

    .app-textarea::placeholder {
        color: var(--text-secondary);
        opacity: 0.7;
    }

    .app-textarea:hover {
        border-color: var(--text-secondary);
    }

    .app-textarea:focus {
        border-color: var(--accent);
        outline: none;
        box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.2);
    }
</style>
