@page "/location"
@using FloodApp.Components.Location
@using FloodApp.Components.UI
@layout FloodApp.Components.Layout.MainLayout

<div class="h-[calc(100vh-60px)] md:h-[calc(100vh-50px)] w-full flex flex-col-reverse md:flex-row overflow-hidden">
    <!-- Left Panel: Form -->
    <div class="location-sidebar flex-1 md:flex-none flex flex-col gap-6 z-10 overflow-y-auto">
        <div class="flex items-center gap-2 mb-1">
            <AppButton Variant="AppButton.ButtonVariant.Ghost" 
                       Color="AppButton.ButtonColor.Neutral"
                       OnClick="@GoBack"
                       Class="px-2 py-1 -ml-2">
                <Icon SvgContent='<path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' />
                Back
            </AppButton>
        </div>
        <div>
            <h1 class="text-2xl font-bold mb-1">Check Location</h1>
            <p class="text-secondary text-sm">Select a region to analyze flood risk.</p>
        </div>
        
        <LocationForm />
        
        <div class="mt-auto text-xs text-secondary text-center">
            Data provided by Disaster Management Center
        </div>
    </div>

    <!-- Right Panel: Map -->
    <div class="h-[40vh] shrink-0 md:h-auto md:flex-1 bg-gray-800 relative z-0">
         <SriLankaRiskMap />
    </div>
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;

    private void GoBack()
    {
        Nav.NavigateTo("/");
    }
}

<style>
    .w-1\/3 { width: 33.333333%; }
    .flex-1 { flex: 1 1 0%; }
    .overflow-hidden { overflow: hidden; }
    .overflow-y-auto { overflow-y: auto; }
    
    .location-sidebar {
        width: 100%;
        padding: 1.25rem;
        background: rgba(15, 23, 42, 0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 -10px 30px rgba(0,0,0,0.5);
    }
    
    @@media (min-width: 768px) {
        .location-sidebar {
            width: 33.333333%;
            min-width: 360px;
            padding: 1.75rem;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 10px 0 30px rgba(0,0,0,0.5);
        }
    }
</style>
