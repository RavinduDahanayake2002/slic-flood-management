@page "/awareness"

<div class="awareness-page min-h-screen pb-16 overflow-hidden">
    
    <!-- Hero Header -->
    <div class="hero-section relative py-16 px-4 md:px-8 mb-12">
        <div class="container mx-auto text-center z-10 relative">
            <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight drop-shadow-lg">
                Flood Awareness & <span class="text-teal-400">Protection Guide</span>
            </h1>
            <p class="text-lg md:text-xl text-slate-300 max-w-2xl mx-auto drop-shadow-md">
                Equip yourself with the knowledge to protect your family, property, and future from unexpected flood disasters.
            </p>
        </div>
        <div class="bg-gradient-radial"></div>
    </div>

    <div class="container mx-auto px-4 md:px-8 space-y-20">
        
        <!-- Section 1: Awareness Cards Row -->
        <section class="fade-in-section">
            <div class="mb-8 text-center">
                <h2 class="text-2xl font-bold text-white mb-2">The Basics</h2>
                <div class="h-1 w-16 bg-teal-500 mx-auto rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
                <!-- Card 1 -->
                <div class="awareness-card @(expandedCard == 1 ? "expanded" : "")" @onclick="() => ToggleCard(1)">
                    <div class="card-icon">🌊</div>
                    <h3 class="card-title">What is Flood Insurance?</h3>
                    <p class="card-preview">A specialized policy offering financial protection against water damage...</p>
                    <div class="card-content">
                        <p>Standard home insurance doesn't usually cover flood damage. Flood insurance is specifically designed to protect your physical structure and belongings from water-related natural disasters, such as heavy monsoons, storm surges, or overflowing rivers.</p>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="awareness-card @(expandedCard == 2 ? "expanded" : "")" @onclick="() => ToggleCard(2)">
                    <div class="card-icon">🛡️</div>
                    <h3 class="card-title">What does SLIC Cover?</h3>
                    <p class="card-preview">Protection for your home's foundation, electrical systems, plumbing...</p>
                    <div class="card-content">
                        <p>SLIC General Flood Insurance covers the structural integrity of your building, electrical and plumbing systems, built-in appliances, carpeting, paneling, and debris removal. Contents coverage for personal belongings can be added as an extension.</p>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="awareness-card @(expandedCard == 3 ? "expanded" : "")" @onclick="() => ToggleCard(3)">
                    <div class="card-icon">📋</div>
                    <h3 class="card-title">How to File a Claim</h3>
                    <p class="card-preview">Follow our simple 3-step digital process for rapid resolution...</p>
                    <div class="card-content">
                        <ol class="list-decimal pl-5 space-y-2 text-slate-300">
                            <li><strong>Report:</strong> Use our portal to report damage safely.</li>
                            <li><strong>Assess:</strong> An SLIC assessor or AI vision tool will review the evidence provided.</li>
                            <li><strong>Resolve:</strong> Receive payout directly to your bank account with minimal paperwork.</li>
                        </ol>
                    </div>
                </div>

                <!-- Card 4 -->
                <div class="awareness-card @(expandedCard == 4 ? "expanded" : "")" @onclick="() => ToggleCard(4)">
                    <div class="card-icon">⚠️</div>
                    <h3 class="card-title">Before a Flood: Checklist</h3>
                    <p class="card-preview">Essential preparatory steps to minimize damage to your property...</p>
                    <div class="card-content">
                        <ul class="list-disc pl-5 space-y-2 text-slate-300">
                            <li>Elevate critical utilities (heaters, electrical panels).</li>
                            <li>Waterproof your basement or ground floor.</li>
                            <li>Prepare emergency survival kits.</li>
                            <li>Store important documents in watertight containers.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 3: Flood Preparedness Timeline -->
        <section class="fade-in-section" style="animation-delay: 0.1s;">
            <div class="mb-12 text-center">
                <h2 class="text-2xl font-bold text-white mb-2">Preparedness Timeline</h2>
                <div class="h-1 w-16 bg-cyan-500 mx-auto rounded-full"></div>
            </div>

            <div class="timeline-stepper">
                <div class="step-card">
                    <div class="step-header bg-cyan-900/40 border-cyan-500/50">
                        <span class="step-icon">⏱️</span>
                        <h4>Before the Flood</h4>
                    </div>
                    <ul class="step-list">
                        <li><span>✓</span> Monitor SLIC Risk App for weather warnings.</li>
                        <li><span>✓</span> Identify your nearest Emergency Shelter.</li>
                        <li><span>✓</span> Move valuables to upper floors.</li>
                        <li><span>✓</span> Review your SLIC insurance policy limits.</li>
                    </ul>
                </div>
                
                <div class="step-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>

                <div class="step-card">
                    <div class="step-header bg-red-900/40 border-red-500/50">
                        <span class="step-icon">🚨</span>
                        <h4>During the Flood</h4>
                    </div>
                    <ul class="step-list">
                        <li><span>✓</span> Evacuate immediately if instructed.</li>
                        <li><span>✓</span> Disconnect all electrical appliances.</li>
                        <li><span>✓</span> Do not walk or drive through floodwaters.</li>
                        <li><span>✓</span> Listen to DMC emergency broadcasts.</li>
                    </ul>
                </div>
                
                <div class="step-arrow hidden lg:flex">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>

                <div class="step-card">
                    <div class="step-header bg-teal-900/40 border-teal-500/50">
                        <span class="step-icon">🌅</span>
                        <h4>After the Flood</h4>
                    </div>
                    <ul class="step-list">
                        <li><span>✓</span> Return home only when declared safe.</li>
                        <li><span>✓</span> Take photos of all damage for claims.</li>
                        <li><span>✓</span> Throw out food exposed to floodwaters.</li>
                        <li><span>✓</span> File your claim via the SLIC app.</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Section 2: FAQ Accordion -->
        <section class="fade-in-section" style="animation-delay: 0.2s;">
            <div class="mb-8 text-center">
                <h2 class="text-2xl font-bold text-white mb-2">Frequently Asked Questions</h2>
                <div class="h-1 w-16 bg-purple-500 mx-auto rounded-full"></div>
            </div>

            <div class="glass-panel rounded-2xl p-2 md:p-6 max-w-4xl mx-auto shadow-2xl w-full">
                @foreach(var faq in faqs)
                {
                    <div class="faq-item border-b border-white/5 last:border-0">
                        <button class="faq-btn w-full flex justify-between items-center py-4 px-2 text-left transition-all" @onclick="() => ToggleFaq(faq.Id)">
                            <span class="text-white font-medium pr-4 @(faq.IsOpen ? "text-purple-400" : "")">@faq.Question</span>
                            <div class="faq-icon-wrapper shrink-0 @(faq.IsOpen ? "open" : "")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 align-middle"><path d="m6 9 6 6 6-6"/></svg>
                            </div>
                        </button>
                        <div class="faq-content-wrapper @(faq.IsOpen ? "open" : "")">
                            <div class="py-2 px-2 pb-5 text-slate-300 text-sm leading-relaxed">
                                @faq.Answer
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <!-- Section 4: CTA Banner -->
        <section class="fade-in-section" style="animation-delay: 0.3s;">
            <div class="cta-banner rounded-3xl p-8 md:p-12 text-center shadow-[0_0_50px_rgba(45,212,191,0.2)]">
                <div class="inline-flex bg-teal-900/50 border border-teal-500/30 text-teal-300 font-semibold px-4 py-1.5 rounded-full text-sm mb-6">
                    Peace of Mind
                </div>
                <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Don't wait for the next flood.</h2>
                <p class="text-lg text-teal-100/70 max-w-2xl mx-auto mb-8">
                    Protect your hard-earned assets today. SLIC provides comprehensive flood cover tailored to your geographical risk zone.
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="/location" class="cta-button-primary">Get a Quote</a>
                    <a href="/find-agent" class="cta-button-ghost">Find an Agent</a>
                </div>
            </div>
        </section>

    </div>
</div>

@code {
    private int expandedCard = -1;

    private void ToggleCard(int cardId)
    {
        if (expandedCard == cardId)
            expandedCard = -1;
        else
            expandedCard = cardId;
    }

    private class FaqItem
    {
        public int Id { get; set; }
        public string Question { get; set; } = "";
        public string Answer { get; set; } = "";
        public bool IsOpen { get; set; }
    }

    private List<FaqItem> faqs = new()
    {
        new() { Id = 1, Question = "Does my home insurance cover floods automatically?", Answer = "No, standard home or property insurance policies typically exclude flood damage. Flood cover must be purchased as a specific add-on or a standalone policy through SLIC General." },
        new() { Id = 2, Question = "What is the waiting period after buying flood cover?", Answer = "SLIC Flood Protection policies have a 14-day mandatory waiting period from the date of purchase before the coverage becomes active. This prevents opportunistic purchases directly prior to an event." },
        new() { Id = 3, Question = "How quickly does SLIC process flood claims?", Answer = "Through our new digital App, if sufficient photographic evidence is provided via the 'Report Damage' portal, preliminary assessments are done by AI within 24 hours. Payouts for clear-cut claims are processed in as little as 3-5 business days." },
        new() { Id = 4, Question = "Which areas in Sri Lanka are classified as flood zones?", Answer = "We use historical and geospatial data (visible in our /risk page) to classify zones into High, Medium, and Low risk. The Kelani, Kalu, Gin, and Nilwala river basins, as well as low-lying coastal urban centers like Colombo, often fall in High/Medium risk." },
        new() { Id = 5, Question = "What documents do I need to file a flood claim?", Answer = "You need your policy number, proof of identity, a digitally submitted statement of the event, and extensive photographic evidence of the damaged structure and contents. For structural repairs, estimates from certified contractors may be required later." },
        new() { Id = 6, Question = "Can I insure my vehicle against flood damage?", Answer = "Yes, vehicle flood protection is available as an extension to your SLIC Comprehensive Motor Insurance policy. It is separate from Property Flood Insurance." },
        new() { Id = 7, Question = "Is agricultural land covered under SLIC flood policies?", Answer = "Standard property flood cover does not include agricultural crops or farming land. SLIC offers a separate 'Agricultural Weather Index Insurance' designed specifically for farmers." },
        new() { Id = 8, Question = "How is the flood risk premium calculated?", Answer = "Premiums are dynamically calculated based on our intelligent ML model. It evaluates your geographical coordinates, historical flood data for your division, structural elevation, and property value to generate a fair and highly personalized rate." },
        new() { Id = 9, Question = "Does the policy cover temporary living expenses?", Answer = "Premium tier policies include a 'Loss of Use' provision, which reimburses emergency accommodation costs up to a specified limit while your property remains uninhabitable." },
        new() { Id = 10, Question = "If I live in a Low Risk zone, do I still need it?", Answer = "Floods can happen anywhere due to sudden drainage blocks or freak weather events (urban flash flooding). While risk is lower, SLIC premiums for low-risk zones are very affordable, making it a highly cost-effective safety net." }
    };

    private void ToggleFaq(int id)
    {
        var faq = faqs.FirstOrDefault(f => f.Id == id);
        if (faq != null)
        {
            faq.IsOpen = !faq.IsOpen;
        }
    }
}

<style>
    .awareness-page {
        background-color: #0f172a;
    }

    .hero-section {
        background: linear-gradient(135deg, rgba(15, 23, 42, 1) 0%, rgba(15, 118, 110, 0.4) 100%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        overflow: hidden;
    }

    .bg-gradient-radial {
        position: absolute;
        top: -50%;
        left: 50%;
        transform: translateX(-50%);
        width: 1000px;
        height: 1000px;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
        z-index: 0;
        pointer-events: none;
    }

    .glass-panel {
        background: rgba(30, 41, 59, 0.4);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    /* Cards */
    .awareness-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1rem;
        padding: 1.5rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }

    .awareness-card:hover {
        background: rgba(30, 41, 59, 0.9);
        border-color: rgba(45, 212, 191, 0.4);
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -1px rgba(0,0,0,0.2), 0 0 20px rgba(45, 212, 191, 0.1);
    }

    .card-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        background: rgba(255,255,255,0.05);
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 1rem;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
        margin-bottom: 0.5rem;
    }

    .card-preview {
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.5;
        transition: opacity 0.3s;
    }

    .card-content {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition: all 0.4s ease-in-out;
        color: #cbd5e1;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .awareness-card.expanded {
        background: rgba(15, 23, 42, 0.9);
        border-color: #2dd4bf;
        box-shadow: inset 0 2px 10px rgba(45, 212, 191, 0.15);
    }

    .awareness-card.expanded .card-preview {
        display: none;
    }

    .awareness-card.expanded .card-content {
        max-height: 300px;
        opacity: 1;
        margin-top: 0.5rem;
    }

    /* Stepper */
    .timeline-stepper {
        display: flex;
        flex-direction: column;
        lg:flex-direction: row;
        gap: 1.5rem;
        align-items: center;
        justify-content: space-center;
        max-width: 1200px;
        margin: 0 auto;
    }
    @@media (min-width: 1024px) {
        .timeline-stepper { flex-direction: row; align-items: stretch; justify-content: center; }
    }

    .step-card {
        flex: 1;
        background: rgba(30, 41, 59, 0.5);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 1rem;
        overflow: hidden;
        width: 100%;
        max-width: 350px;
    }

    .step-header {
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border-bottom: 1px solid;
    }

    .step-header h4 {
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        margin: 0;
    }

    .step-icon {
        font-size: 1.5rem;
    }

    .step-list {
        padding: 1.5rem;
        list-style: none;
        margin: 0;
    }

    .step-list li {
        color: #cbd5e1;
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: start;
        gap: 0.5rem;
    }

    .step-list li span {
        color: #2dd4bf;
        font-weight: bold;
    }

    .step-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    @@media (max-width: 1023px) {
        .step-arrow svg { transform: rotate(90deg); }
    }

    /* FAQ */
    .faq-btn:hover { background: rgba(255,255,255,0.02); }
    
    .faq-icon-wrapper {
        transition: transform 0.3s ease;
    }
    .faq-icon-wrapper.open {
        transform: rotate(180deg);
        color: #c084fc;
    }
    .faq-icon-wrapper.open svg { color: #c084fc; }

    .faq-content-wrapper {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.3s ease-in-out;
    }
    .faq-content-wrapper.open {
        grid-template-rows: 1fr;
    }
    .faq-content-wrapper > div {
        overflow: hidden;
    }

    /* CTA */
    .cta-banner {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(13, 148, 136, 0.5) 100%);
        border: 1px solid rgba(45, 212, 191, 0.3);
        position: relative;
        overflow: hidden;
    }
    .cta-banner::before {
        content: '';
        position: absolute;
        top: -50%; left: -50%; width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(14, 165, 233, 0.15) 0%, transparent 60%);
        animation: rotate 20s linear infinite;
        z-index: 0;
        pointer-events: none;
    }
    
    .cta-button-primary {
        position: relative;
        z-index: 10;
        background: white;
        color: #0f172a;
        font-weight: 700;
        padding: 0.8rem 2rem;
        border-radius: 9999px;
        transition: all 0.2s;
        box-shadow: 0 10px 20px -5px rgba(255,255,255,0.3);
    }
    .cta-button-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 25px -5px rgba(255,255,255,0.5);
        background: #f8fafc;
    }

    .cta-button-ghost {
        position: relative;
        z-index: 10;
        background: transparent;
        color: white;
        font-weight: 600;
        border: 2px solid rgba(255,255,255,0.2);
        padding: 0.8rem 2rem;
        border-radius: 9999px;
        transition: all 0.2s;
    }
    .cta-button-ghost:hover {
        background: rgba(255,255,255,0.1);
        border-color: white;
    }
    
    @@keyframes rotate {
        100% { transform: rotate(360deg); }
    }

    .fade-in-section {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @@keyframes fadeInUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>
