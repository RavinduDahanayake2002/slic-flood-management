@page "/find-agent"
@using FloodApp.Services
@inject AgentLocatorService AgentService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="agent-page flex flex-col h-screen overflow-hidden">
    <!-- Header Area -->
    <div class="header-section shrink-0 relative z-50 pt-4">
        <div class="container mx-auto px-6 relative z-50">
        <BackButton OnClick="@GoBack" />
        </div>
        <div class="container mx-auto px-6 py-4 text-center">
            <h1 class="text-3xl font-bold text-white mb-2 tracking-tight">Find Your Nearest SLIC Agent</h1>
            <p class="text-secondary">Walk in or call — we're here to protect you.</p>
        </div>

        <!-- Search Bar -->
        <div class="container mx-auto px-6 pb-6">
            <div class="glass-search p-3 rounded-2xl flex flex-col md:flex-row gap-4 items-center fade-in shadow-xl">
                <select @bind="selectedProvince" class="form-select glass-input flex-shrink-0">
                    <option value="All">All Provinces</option>
                    <option value="Western">Western</option>
                    <option value="Southern">Southern</option>
                    <option value="Central">Central</option>
                    <option value="North Western">North Western</option>
                    <option value="Northern">Northern</option>
                    <option value="Eastern">Eastern</option>
                    <option value="Sabaragamuwa">Sabaragamuwa</option>
                    <option value="North Central">North Central</option>
                    <option value="Uva">Uva</option>
                </select>

                <div class="relative w-full flex-grow">
                    <input type="text" @bind="searchTerm" @bind:event="oninput" 
                           placeholder="Search by city or agent name..." 
                           class="glass-input w-full pl-10" />
                    <svg class="absolute left-3 top-2.5 text-slate-400" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </div>

                <button class="btn-primary-glow whitespace-nowrap" @onclick="UseMyLocation" disabled="@isLocating">
                    @if (isLocating)
                    {
                        <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        <span>Locating...</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
                        <span>Use My Location</span>
                    }
                </button>
            </div>
        </div>
    </div>

    <!-- Split Layout Area -->
    <div class="flex-grow flex flex-col md:flex-row h-full overflow-hidden relative border-t border-slate-700/50">
        
        <!-- Left Panel: Agent List (40%) -->
        <div class="w-full md:w-2/5 h-full overflow-y-auto agent-list-panel p-4 z-10 custom-scrollbar">
            @if (!filteredAgents.Any())
            {
                <div class="text-center p-8 mt-10">
                    <p class="text-slate-400 text-lg">No agents found matching your search.</p>
                </div>
            }
            else
            {
                <div class="flex flex-col gap-4 pb-10">
                    @foreach (var agent in filteredAgents)
                    {
                        <div class="agent-card @(selectedAgentId == agent.Id ? "active-card" : "") p-5 rounded-xl cursor-pointer transition-all"
                             @onclick="() => SelectAgent(agent)">
                            
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="text-lg font-bold text-white group-hover:text-[#00B2AA] transition-colors">@agent.Name</h3>
                                @if (agent.Type == "Branch")
                                {
                                    <span class="badge bg-purple-900/40 text-purple-300 border border-purple-500/30">Branch</span>
                                }
                                else
                                {
                                    <span class="badge bg-cyan-900/40 text-cyan-300 border border-cyan-500/30">Agent</span>
                                }
                            </div>
                            
                            <p class="text-secondary text-sm mb-3 flex items-start gap-2">
                                <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                <span>@agent.Address, @agent.City</span>
                            </p>
                            
                            <div class="flex items-center gap-2 mb-4">
                                <a href="tel:@agent.Phone.Replace(" ", "")" class="text-[#00B2AA] hover:text-[#00BCD4] font-medium text-sm flex items-center gap-1 bg-[#00B2AA]/20 px-2 py-1 rounded-md" @onclick:stopPropagation>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    @agent.Phone
                                </a>
                                
                                @if (agent.DistanceKm.HasValue)
                                {
                                    <span class="text-xs font-semibold text-slate-300 ml-auto bg-slate-800 px-2 py-1 rounded-md border border-slate-700">
                                        @(agent.DistanceKm.Value.ToString("F1")) km away
                                    </span>
                                }
                            </div>
                            
                            <div class="flex gap-2">
                                <button class="action-btn flex-1" @onclick="() => SelectAgent(agent)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    View on Map
                                </button>
                                <a href="https://www.google.com/maps/dir/?api=1&destination=@agent.Latitude,@agent.Longitude" target="_blank" class="action-btn-outline" @onclick:stopPropagation>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Right Panel: Leaflet Map (60%) -->
        <div class="w-full md:w-3/5 h-full relative z-0">
            <div id="agent-locator-map" class="w-full h-full"></div>
            
            <!-- Locator map gradient overlay to fade edges -->
            <div class="absolute inset-y-0 left-0 w-8 bg-gradient-to-r from-[#0f172a] to-transparent pointer-events-none z-[400] hidden md:block"></div>
        </div>
    </div>
</div>

@code {
    private List<SlicAgent> filteredAgents = new();
    
    // JS Module
    private IJSObjectReference? mapModule;
    private IJSObjectReference? mapInstance;

    private string _selectedProvince = "All";
    private string selectedProvince
    {
        get => _selectedProvince;
        set { _selectedProvince = value; _ = ApplyFilters(); }
    }

    private string _searchTerm = "";
    private string searchTerm
    {
        get => _searchTerm;
        set { _searchTerm = value; _ = ApplyFilters(); }
    }

    private double? userLat;
    private double? userLng;
    private bool isLocating = false;
    private string selectedAgentId = "";

    protected override async Task OnInitializedAsync()
    {
        await ApplyFilters();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            mapModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/map.js");
            
            // Initialize map centered on SL roughly
            mapInstance = await mapModule.InvokeAsync<IJSObjectReference>("initMap", "agent-locator-map", new { lat = 7.8731, lng = 80.7718 }, 7, null);
            
            await ReDrawMap();
        }
    }

    private async Task ApplyFilters()
    {
        filteredAgents = AgentService.SearchAgents(_searchTerm, _selectedProvince, userLat, userLng);
        if (mapModule != null && mapInstance != null)
        {
            await ReDrawMap();
        }
        StateHasChanged();
    }

    private async Task ReDrawMap()
    {
        if (mapModule == null || mapInstance == null) return;

        // Clear existing
        try { await mapModule.InvokeVoidAsync("clearAgentMap", mapInstance); } catch { }

        // Add agents
        foreach(var agent in filteredAgents)
        {
            var pContent = $"<b>{agent.Name}</b><br>{agent.Phone}<br>{agent.Address}";
            try { await mapModule.InvokeVoidAsync("addAgentMarker", mapInstance, agent.Latitude, agent.Longitude, agent.Type, pContent); } catch { }
        }

        // Draw User logic
        if (userLat.HasValue && userLng.HasValue)
        {
            try { await mapModule.InvokeVoidAsync("addUserLocation", mapInstance, userLat.Value, userLng.Value); } catch { }
            
            // Draw line to nearest agent if there's any
            if (filteredAgents.Any())
            {
                var nearest = filteredAgents.First();
                try { await mapModule.InvokeVoidAsync("drawRouteLine", mapInstance, userLat.Value, userLng.Value, nearest.Latitude, nearest.Longitude); } catch { }
            }
        }
    }

    private async Task SelectAgent(SlicAgent agent)
    {
        selectedAgentId = agent.Id;
        if (mapModule != null && mapInstance != null)
        {
            try { await mapModule.InvokeVoidAsync("setView", mapInstance, agent.Latitude, agent.Longitude, 12); } catch { }
        }
    }

    private async Task UseMyLocation()
    {
        if (isLocating) return;
        
        isLocating = true;
        StateHasChanged();

        try
        {
            // Simple generic geolocation via JS
            var result = await JS.InvokeAsync<double[]>("eval", "new Promise((res, rej) => navigator.geolocation.getCurrentPosition(p => res([p.coords.latitude, p.coords.longitude]), e => rej(e)))");
            if (result != null && result.Length == 2)
            {
                userLat = result[0];
                userLng = result[1];
                
                // Clear filters when auto-locating
                _selectedProvince = "All";
                _searchTerm = "";
                await ApplyFilters(); // Will redraw automatically
            }
        }
        catch (Exception)
        {
            // Usually occurs if user denies permission
            Console.WriteLine("Geolocation failed or denied.");
        }
        finally
        {
            isLocating = false;
            StateHasChanged();
        }
    }

    private void GoBack() => Nav.NavigateTo("/location");
}

<style>
    .agent-page {
        background-color: var(--bg-dark);
    }

    .header-section {
        background-image: radial-gradient(circle at 50% -20%, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
    }

    .glass-search {
        background: rgba(30, 41, 59, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .glass-input {
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        padding: 0.6rem 1rem;
        border-radius: 0.5rem;
        outline: none;
        transition: all 0.2s;
    }
    
    .glass-input:focus {
        border-color: #2dd4bf;
        box-shadow: 0 0 0 2px rgba(45, 212, 191, 0.2);
    }
    
    .glass-input option {
        background: #1e293b;
        color: white;
    }

    .btn-primary-glow {
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        color: white;
        padding: 0.6rem 1.25rem;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        font-weight: 600;
        transition: all 0.3s ease;
        border: 1px solid rgba(56, 189, 248, 0.3);
        box-shadow: 0 0 15px rgba(2, 132, 199, 0.4);
    }

    .btn-primary-glow:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 0 25px rgba(2, 132, 199, 0.7);
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
    }
    
    .btn-primary-glow:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .agent-list-panel {
        background: rgba(15, 23, 42, 0.95);
        box-shadow: inset -10px 0 20px -10px rgba(0,0,0,0.5);
    }

    .agent-card {
        background: rgba(17, 34, 64, 0.4);
        border: 1px solid var(--border-soft);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    
    .agent-card:hover {
        background: rgba(17, 34, 64, 0.75);
        border-color: rgba(0, 178, 170, 0.3);
        transform: translateY(-2px);
    }

    .active-card {
        background: rgba(17, 34, 64, 0.95);
        border-color: var(--color-purple);
        box-shadow: 0 0 20px rgba(124, 58, 237, 0.2);
    }

    .badge {
        font-size: 0.7rem;
        padding: 0.15rem 0.5rem;
        border-radius: 9999px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .action-btn {
        background: rgba(0, 178, 170, 0.1);
        color: #00B2AA;
        border: 1px solid rgba(0, 178, 170, 0.2);
        padding: 0.5rem;
        border-radius: 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .action-btn:hover {
        background: rgba(0, 178, 170, 0.2);
        border-color: rgba(0, 178, 170, 0.4);
    }
    
    .action-btn-outline {
        background: transparent;
        color: #94a3b8;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.5rem;
        border-radius: 0.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    
    .action-btn-outline:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(15, 23, 42, 1);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(71, 85, 105, 0.5);
        border-radius: 3px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(71, 85, 105, 0.8);
    }

    .fade-in {
        animation: fadeIn 0.6s ease-out forwards;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Global Map Marker Animations */
    @@keyframes mapPulse {
        0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7); }
        70% { box-shadow: 0 0 0 20px rgba(59, 130, 246, 0); }
        100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
    }
</style>
