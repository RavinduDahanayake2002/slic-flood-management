@page "/premium"
@layout FloodApp.Components.Layout.MainLayout

<div class="page-container">
    <div class="glass-header">
        <h1>Premium Calculation</h1>
        <p>Calculate your insurance premium based on localized risk factors.</p>
    </div>

    <div class="calc-grid">
        <div class="feature-card">
            <h2>Instant Quote</h2>
            <p>Enter your details below to receive an estimated insurance premium rating based on Flood and Landslide risks.</p>
            
            <div class="form-placeholder">
                <div class="input-row">
                    <div class="input-group">
                        <label>Property Value (LKR)</label>
                        <div class="fake-input">1,000,000</div>
                    </div>
                </div>
                <button class="btn-calc">Calculate Premium</button>
            </div>
        </div>

        <div class="results-card">
            <div class="total-premium">
                <span class="label">Estimated Yearly Premium</span>
                <span class="value">Rs. 12,500.00*</span>
            </div>
            <p class="disclaimer">*Subject to full survey and verification.</p>
        </div>
    </div>
</div>

<style>
    .page-container {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .glass-header {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        padding: 2rem;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 2rem;
    }

    .glass-header h1 {
        margin: 0;
        font-size: 2rem;
        color: var(--accent);
    }

    .calc-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 2rem;
    }

    .feature-card, .results-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 2rem;
        border-radius: 20px;
    }

    .btn-calc {
        width: 100%;
        background: var(--accent);
        color: black;
        border: none;
        padding: 1rem;
        border-radius: 8px;
        font-weight: 700;
        margin-top: 2rem;
        opacity: 0.5;
        cursor: not-allowed;
    }

    .total-premium {
        text-align: center;
        padding: 2rem;
        background: rgba(23, 180, 183, 0.1);
        border-radius: 16px;
        border: 1px solid var(--accent);
    }

    .total-premium .label {
        display: block;
        font-size: 0.9rem;
        color: var(--accent);
        margin-bottom: 0.5rem;
    }

    .total-premium .value {
        font-size: 2rem;
        font-weight: 700;
        color: white;
    }

    .disclaimer {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
        text-align: center;
        margin-top: 1rem;
    }

    .fake-input {
        background: rgba(255, 255, 255, 0.05);
        padding: 0.75rem;
        border-radius: 8px;
        color: rgba(255, 255, 255, 0.3);
    }

    @@media (max-width: 900px) {
        .calc-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
